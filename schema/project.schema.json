{
  "$id": "https://github.com/lluiseriksson/rooted-tree-catalan-closure/raw/master/schema/project.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "actions_policy": {
      "const": "archive/github-actions-policy.json",
      "type": "string"
    },
    "claim_boundary": {
      "properties": {
        "closed_exact_catalan_identity": {
          "const": false
        },
        "conditional_downstream_adapter": {
          "const": true
        }
      },
      "required": [
        "closed_exact_catalan_identity",
        "conditional_downstream_adapter"
      ],
      "type": "object"
    },
    "critical_git_blobs": {
      "additionalProperties": {
        "pattern": "^[0-9a-f]{40}$",
        "type": "string"
      },
      "minProperties": 1,
      "type": "object"
    },
    "default_branch": {
      "const": "master"
    },
    "expected_axioms": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "finite_evidence": {
      "properties": {
        "graph_max_n": {
          "const": 7
        },
        "max_n": {
          "const": 8
        },
        "status": {
          "const": "finite_exact_computational_evidence_not_formal_proof"
        }
      },
      "required": [
        "file",
        "max_n",
        "graph_max_n",
        "methods",
        "status"
      ],
      "type": "object"
    },
    "history_backup_outputs": {
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "type": "array",
      "uniqueItems": true
    },
    "history_inventory_schema": {
      "const": 2,
      "type": "integer"
    },
    "name": {
      "const": "rooted-tree-catalan-closure"
    },
    "recovery_policy": {
      "properties": {
        "history_bundle_byte_reproducibility_claim": {
          "const": false
        },
        "off_site_storage_recommended": {
          "const": true
        }
      },
      "required": [
        "source_tree",
        "git_history",
        "off_site_storage_recommended",
        "history_bundle_byte_reproducibility_claim"
      ],
      "type": "object"
    },
    "release_date": {
      "format": "date",
      "type": "string"
    },
    "release_outputs": {
      "items": {
        "type": "string"
      },
      "minItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "release_policy": {
      "properties": {
        "archive_method": {
          "const": "ZIP_STORED"
        },
        "archive_resource_limits": {
          "const": true
        },
        "clean_git_worktree_required": {
          "const": true
        },
        "complete_release_checksums": {
          "const": true
        },
        "cross_runtime_byte_determinism": {
          "const": true
        },
        "github_provenance_attestations": {
          "const": true
        },
        "history_bundle_exact_head_inventory": {
          "const": true
        },
        "host_extracted_modes_authoritative": {
          "const": false
        },
        "non_destructive_powershell_build": {
          "const": true
        },
        "portable_archive_paths": {
          "const": true
        },
        "release_output_exact_inventory": {
          "const": true
        },
        "source_archive_repackaging": {
          "const": true
        },
        "source_archive_self_audit": {
          "const": true
        },
        "source_manifest_self_check": {
          "const": true
        },
        "spdx_2_3_conformant_checksums": {
          "const": true
        },
        "standalone_source_zip_verifier": {
          "const": true
        },
        "strict_json_metadata": {
          "const": true
        },
        "tracked_git_files_only": {
          "const": true
        }
      },
      "required": [
        "archive_method",
        "archive_resource_limits",
        "clean_git_worktree_required",
        "complete_release_checksums",
        "cross_runtime_byte_determinism",
        "github_provenance_attestations",
        "history_bundle_exact_head_inventory",
        "host_extracted_modes_authoritative",
        "non_destructive_powershell_build",
        "normalized_timestamp",
        "portable_archive_paths",
        "release_output_exact_inventory",
        "source_archive_repackaging",
        "source_archive_self_audit",
        "source_manifest_self_check",
        "spdx_2_3_conformant_checksums",
        "standalone_source_zip_verifier",
        "strict_json_metadata",
        "tracked_git_files_only"
      ],
      "type": "object"
    },
    "repository": {
      "format": "uri",
      "type": "string"
    },
    "schema_version": {
      "const": 5
    },
    "status": {
      "const": "recovered_conditional_publication_artifact"
    },
    "tooling_python_versions": {
      "const": [
        "3.11",
        "3.12",
        "3.13"
      ],
      "type": "array"
    },
    "unresolved_obligation": {
      "const": "YangMills.KP.RootedChildFactorialCatalanIdentity n for every n"
    },
    "upstream": {
      "properties": {
        "base_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "checked_patch_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "mathlib_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "base_commit",
        "checked_patch_commit",
        "lean_toolchain",
        "mathlib_commit"
      ],
      "type": "object"
    },
    "verified_declarations": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    }
  },
  "required": [
    "actions_policy",
    "claim_boundary",
    "critical_git_blobs",
    "default_branch",
    "expected_axioms",
    "finite_evidence",
    "history_backup_outputs",
    "history_inventory_schema",
    "name",
    "recovery_policy",
    "release_date",
    "release_outputs",
    "release_policy",
    "repository",
    "schema_version",
    "status",
    "theorem_manifest",
    "tooling_python_versions",
    "unresolved_obligation",
    "upstream",
    "verified_declarations",
    "version"
  ],
  "title": "Rooted-tree Catalan closure project metadata",
  "type": "object"
}
