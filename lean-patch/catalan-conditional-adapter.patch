+import Mathlib.Analysis.SpecialFunctions.Pow.Real
+
+/-!
+# Square-root Catalan closure
+
+This file contains the real-valued square-root closure used by the Catalan
+majorant.  It is independent of the polymer and rooted-tree APIs.
+
+Oracle target: `[propext, Classical.choice, Quot.sound]`.
+-/
+
+namespace YangMills.RG
+
+noncomputable def catalanClosure (M Œµ : ‚Ñù) : ‚Ñù :=
+  (1 - Real.sqrt (1 - 4 * M ^ 2 * Œµ)) / (2 * M)
+
+noncomputable def geometricClosure (M Œµ : ‚Ñù) : ‚Ñù :=
+  M * Œµ / (1 - 4 * M ^ 2 * Œµ)
+
+theorem catalanClosure_fixedPoint
+    {M Œµ : ‚Ñù} (hM : 0 < M) (hŒµ : 0 ‚â§ Œµ)
+    (hsmall : 4 * M ^ 2 * Œµ ‚â§ 1) :
+    catalanClosure M Œµ =
+      M * Œµ + M * (catalanClosure M Œµ) ^ 2 := by
+  have hrad : 0 ‚â§ 1 - 4 * M ^ 2 * Œµ := by nlinarith
+  have _ : 0 ‚â§ Œµ := hŒµ
+  have hsqrt_sq : Real.sqrt (1 - 4 * M ^ 2 * Œµ) ^ 2 =
+      1 - 4 * M ^ 2 * Œµ := by
+    exact Real.sq_sqrt hrad
+  unfold catalanClosure
+  field_simp [ne_of_gt hM, (show (2 : ‚Ñù) * M ‚âÝ 0 by positivity)]
+  nlinarith
+
+theorem catalanClosure_nonneg
+    {M Œµ : ‚Ñù} (hM : 0 < M) (hŒµ : 0 ‚â§ Œµ)
+    (hsmall : 4 * M ^ 2 * Œµ ‚â§ 1) :
+    0 ‚â§ catalanClosure M Œµ := by
+  have hrad : 0 ‚â§ 1 - 4 * M ^ 2 * Œµ := by nlinarith
+  have hrad_le_one : 1 - 4 * M ^ 2 * Œµ ‚â§ 1 := by
+    have hprod : 0 ‚â§ 4 * M ^ 2 * Œµ := by positivity
+    linarith
+  have hsqrt_le_one : Real.sqrt (1 - 4 * M ^ 2 * Œµ) ‚â§ 1 := by
+    simpa [Real.sqrt_one] using Real.sqrt_le_sqrt hrad_le_one
+  unfold catalanClosure
+  exact div_nonneg (by nlinarith) (by positivity)
+
+end YangMills.RG
